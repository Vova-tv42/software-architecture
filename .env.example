# Recommended for most uses
DATABASE_URL=postgresql://neondb_owner:url

# For uses requiring a connection without pgbouncer
DATABASE_URL_UNPOOLED=postgresql://neondb_owner:url

# Parameters for constructing your own connection string
PGHOST=
PGHOST_UNPOOLED=
PGUSER=neondb_owner
PGDATABASE=neondb
PGPASSWORD=password

# Parameters for Vercel Postgres Templates
POSTGRES_URL=postgresql://neondb_owner:url
POSTGRES_URL_NON_POOLING=postgresql://neondb_owner:url
POSTGRES_USER=neondb_owner
POSTGRES_HOST=host
POSTGRES_PASSWORD=password
POSTGRES_DATABASE=neondb
POSTGRES_URL_NO_SSL=postgresql://neondb_owner:password@host/neondb
POSTGRES_PRISMA_URL=postgresql://neondb_owner:password@host/neondb
